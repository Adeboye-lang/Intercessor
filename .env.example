# Managed PostgreSQL (required for local and Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require&pgbouncer=true"

# Public app URL used for sitemap/SEO links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="user@example.com"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM_EMAIL="\"Intercessor\" <no-reply@example.com>"
CONTACT_EMAIL_TO="contact@intercessor.uk"

# Google Maps
# Server-side key for Geocoding API + Places API
GOOGLE_MAPS_SERVER_API_KEY="replace-with-server-key"
# Browser key for Maps JavaScript API only
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="replace-with-browser-key"
